# Root project .gitignore
# ONLY push: aqindia/, aqindia-docs/, jupyter-notebooks v2/, scripts/, README.md

# ============================================
# IGNORE EVERYTHING BY DEFAULT
# ============================================
/*
!/

# ============================================
# ALLOW ONLY THESE FOLDERS/FILES
# ============================================

# Allow main application
!aqindia/

# Allow documentation
!aqindia-docs/

# Allow ML notebooks
!jupyter-notebooks v2/

# Allow scripts
!scripts/

# Allow root README
!README.md

# ============================================
# NOW IGNORE SPECIFIC THINGS INSIDE ALLOWED FOLDERS
# ============================================

# Global ignores (apply everywhere)
*.pyc
__pycache__/
*.pyo
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*.swn
*.log
npm-debug.log*
pnpm-debug.log*
*.bak
*.backup
*.old
temp_*.md
temp_*.mmd
temp_*.svg
*.drawio
*.drawio.svg
dist/
build/
*.min.js
*.min.css
coverage/
.nyc_output/
*.tsbuildinfo
.ipynb_checkpoints/
venv/
env/
.env/
.manus/
.manus-logs/
.webdev/
.qoder/
.agents/
.augment/
*_PROMPT*.txt
*_FOR_AI*.txt
PROJECT_CONTEXT*.txt
QUICK_PROMPT.txt
MASTER_PROMPT*.txt
*.skill.md
SKILLS_COMMANDS.md
skills-lock.json
generate-report*.js
generate-report*.py
"Project report For college/"
"Backup Project report For college/"
report-figures/

# --- INSIDE aqindia/ ---
# Node modules (users run pnpm install)
aqindia/node_modules/

# Build outputs
aqindia/dist/

# Environment files (security - NEVER push)
aqindia/.env
aqindia/.env.local
aqindia/.env.production

# Large dataset files (>50MB - GitHub limit is 100MB)
# These are documented in README.md for reproducibility
aqindia/server/data/historical.json
aqindia/server/data/kaggle_historical_original.json

# Backup files (not needed in production)
aqindia/server/data/cities_backup_full_276.json
aqindia/server/data/kaggle_historical_original.json.backup

# Pickle files (ML models - document in README instead)
# *.pkl

# --- INSIDE jupyter-notebooks v2/ ---
# Large CSV datasets (>50MB)
jupyter-notebooks v2/datasets/*.csv

# Trained model files
jupyter-notebooks v2/models/*.pkl
jupyter-notebooks v2/models/*.h5

# Large notebook outputs (keep notebooks, remove huge outputs)
# Notebooks are kept but users can re-run them

# --- INSIDE aqindia-docs/ ---
# No exclusions needed - all docs are important
